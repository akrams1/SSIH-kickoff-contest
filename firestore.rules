rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
             && request.auth.uid == 'oLCpKQT1RNZ9BciPaXdgqhgKYyI2';
    }
    function votingOpen() {
      return !exists(/databases/$(database)/documents/config/event)
             || get(/databases/$(database)/documents/config/event).data.open != false;
    }
    match /contestants/{id} {
      function isSingleVote() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
               && request.resource.data.votes is int
               && request.resource.data.votes == resource.data.votes + 1;
      }
      allow read: if true;
      allow update: if (isSingleVote() && votingOpen()) || isAdmin();
      allow create, delete: if isAdmin();
    }
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /attendees/{id} {
      allow read, write: if isAdmin();
    }
    match /report/{doc} {
      allow read, write: if isAdmin();
    }
    match /photos/{id} {
      function isValidPhoto() {
        return request.resource.data.keys().hasOnly(['url', 'publicId', 'createdAt'])
               && request.resource.data.url is string
               && request.resource.data.url.size() > 0
               && request.resource.data.url.size() < 500
               && request.resource.data.url.matches('https://res[.]cloudinary[.]com/.*')
               && request.resource.data.publicId is string
               && request.resource.data.publicId.size() < 200
               && request.resource.data.createdAt == request.time;
      }
      allow read: if isAdmin();
      allow create: if votingOpen() && isValidPhoto();
      allow update: if false;
      allow delete: if isAdmin();
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
